# ── Infrastructure ────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
CADDY_EMAIL=you@yourdomain.com

# External Docker networks that Caddy must join to reverse-proxy services
# running in sibling compose stacks on the same host. Names must match the
# actual `docker network ls` output (compose prefixes the stack name).
#
# The compose file falls back to sensible defaults (beacon_jsp-net,
# lumen_lumen-net, lumen_monitoring-net) so leaving these unset is fine
# when the beacon and lumen stacks use their standard network names. Only
# uncomment + set if you've renamed those stacks or want to point Caddy at
# different networks.
#
# EXTERNAL_NET_1=beacon_jsp-net
# EXTERNAL_NET_2=lumen_lumen-net
# EXTERNAL_NET_3=lumen_monitoring-net

# Shared PostgreSQL — single user for all portfolio databases
PORTFOLIO_DB_PASSWORD=change-me-strong-password

# ── Django secret keys (generate with: python -c "import secrets; print(secrets.token_hex(50))") ──
INGEST_SECRET_KEY=change-me
EXPLORER_SECRET_KEY=change-me

# ── Shopify ERP Integration ───────────────────────────────────────────────────
SHOPIFY_ERP_API_KEY=
SHOPIFY_ERP_API_SECRET=
SHOPIFY_ERP_WEBHOOK_SECRET=
SHOPIFY_ERP_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ERP_ACCESS_TOKEN=shpat_...

# ── Shopify Order Exception Agent ─────────────────────────────────────────────
SHOPIFY_ORDER_API_KEY=
SHOPIFY_ORDER_API_SECRET=
SHOPIFY_ORDER_WEBHOOK_SECRET=
SHOPIFY_ORDER_STORE_DOMAIN=
ANTHROPIC_API_KEY_ORDER=

# ── Shopify Inventory Discrepancy Agent ───────────────────────────────────────
SHOPIFY_INVENTORY_API_KEY=
SHOPIFY_INVENTORY_API_SECRET=
SHOPIFY_INVENTORY_WEBHOOK_SECRET=
SHOPIFY_INVENTORY_STORE_DOMAIN=
ANTHROPIC_API_KEY_INVENTORY=

# ── Shopify Metaobjects Webhook Server ────────────────────────────────────────
SHOPIFY_METAOBJECTS_API_KEY=
SHOPIFY_METAOBJECTS_API_SECRET=
SHOPIFY_METAOBJECTS_WEBHOOK_SECRET=
SHOPIFY_METAOBJECTS_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_METAOBJECTS_ACCESS_TOKEN=shpat_...

# ── Headless WordPress CMS ────────────────────────────────────────────────────
WP_DB_PASSWORD=change-me-strong-password
WP_DB_ROOT_PASSWORD=change-me-strong-root-password
WP_HEADLESS_API_TOKEN=change-me
WP_NEXT_REVALIDATE_URL=https://your-vercel-app.vercel.app/api/revalidate
WP_REVALIDATION_SECRET=change-me

# ── Portfolio Issues Agent (LangGraph + Slack HITL → GitHub issues) ───────────
ANTHROPIC_API_KEY_ISSUES=sk-ant-...
PORTFOLIO_ISSUES_BEACON_JWT=
PORTFOLIO_ISSUES_GITHUB_TOKEN=ghp_...        # needs `repo` (or `public_repo`) scope
PORTFOLIO_ISSUES_SLACK_BOT_TOKEN=xoxb-...
PORTFOLIO_ISSUES_SLACK_SIGNING_SECRET=
PORTFOLIO_ISSUES_SLACK_CHANNEL_ID=C0123ABCD
# optional overrides — defaults are sun 09:00 weekly + sonnet-4-6
PORTFOLIO_ISSUES_AGENT_MODEL=claude-sonnet-4-6
PORTFOLIO_ISSUES_CRON_DAY_OF_WEEK=sun
PORTFOLIO_ISSUES_CRON_HOUR=9
# Cap proposals per audit (default 5, 0 disables). Findings are ranked by
# drift density so the lowest-signal ones get dropped first.
PORTFOLIO_ISSUES_MAX_PROPOSALS_PER_RUN=5
# BEACON_API_URL defaults to https://beacon.${DOMAIN} — override if your Beacon is elsewhere
BEACON_API_URL=

# Note: oc-realestate-intel was moved off this orchestrator to a Terraform-managed
# AWS EC2 (see terraform/ and ADR-0002). Its OCI_* env vars live in AWS Secrets
# Manager under marquez-oci/*, not here.

# ── jd-role-classifier (BERT/LoRA + spaCy NER for JD role classification) ─────
# Both default to false (service runs but returns no predictions). Set ONE.
#   true/false flags — quoted not needed; compose accepts bare booleans.
# MOCK_NLP=true            → keyword-overlap fallback (no GPU, lower quality)
# LOAD_CLASSIFIER=true     → fine-tuned BERT+LoRA (needs MODEL_PATH + likely GPU)
JD_CLASSIFIER_MOCK_NLP=false
JD_CLASSIFIER_LOAD=false
